  {
    "id": "airframes-events-build",
    "type": "function",
    "z": "airframes-tab",
    "name": "Build events JSON",
    "func": "function normalize(record) {\n    if (!record || typeof record !== \"object\") {\n        return null;\n    }\n\n    if (record.raw || record.received_at || record.airframe_icao) {\n        return record;\n    }\n\n    const flight = record.flight || {};\n    const airframe = record.airframe || {};\n    const station = record.station || {};\n\n    return {\n        received_at: record.received_at,\n        id: record.id,\n        timestamp: record.timestamp || record.created_at,\n        station: station.ident,\n        country: station.country_code,\n        flight: flight.flight_iata || flight.flight_icao || flight.flight,\n        airframe_icao: airframe.icao,\n        tail: airframe.tail || record.tail,\n        military: airframe.military,\n        source: record.source,\n        source_type: record.source_type,\n        frequency: record.frequency,\n        label: record.label,\n        mode: record.mode,\n        text: record.text,\n        raw: record\n    };\n}\n\nconst limit = Math.max(1, Math.min(parseInt(msg.req?.query?.limit || \"250\", 10) || 250, 2000));\nconst lines = String(msg.payload || \"\").split(/\\r?\\n/).filter(Boolean);\nconst stored = [];\n\nfor (let i = lines.length - 1; i >= 0 && stored.length < limit; i--) {\n    try {\n        const parsed = normalize(JSON.parse(lines[i]));\n        if (parsed) {\n            stored.push(parsed);\n        }\n    } catch (err) {\n        // Ignore old non-JSON lines.\n    }\n}\n\nconst recent = flow.get(\"airframes_recent\") || [];\nconst byId = new Map();\nfor (const event of [...recent, ...stored]) {\n    const key = event.id || `${event.timestamp}-${event.station}-${event.text}`;\n    if (!byId.has(key)) {\n        byId.set(key, event);\n    }\n}\n\nmsg.headers = { \"content-type\": \"application/json; charset=utf-8\", \"cache-control\": \"no-store\" };\nmsg.payload = JSON.stringify([...byId.values()].slice(0, limit));\nreturn msg;",
