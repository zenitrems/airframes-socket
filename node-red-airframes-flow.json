    "id": "airframes-normalize",
    "type": "function",
    "z": "airframes-tab",
    "name": "Normalize, cache and route",
    "func": "function looksLikeAirframesEvent(value) {\n    return value && typeof value === \"object\" && (\n        value.id || value.timestamp || value.station || value.airframe || value.source\n    );\n}\n\nfunction extractEvent(value) {\n    if (!value || typeof value !== \"object\") {\n        return {};\n    }\n\n    if (looksLikeAirframesEvent(value)) {\n        return value;\n    }\n\n    for (const key of [\"payload\", \"event\", \"message\", \"data\"]) {\n        if (looksLikeAirframesEvent(value[key])) {\n            return value[key];\n        }\n    }\n\n    return value;\n}\n\nconst envelope = msg.payload || {};\nconst event = extractEvent(envelope);\nconst flight = event.flight || {};\nconst airframe = event.airframe || {};\nconst station = event.station || {};\nconst now = new Date().toISOString();\n\nconst normalized = {\n    received_at: now,\n    id: event.id,\n    timestamp: event.timestamp || event.created_at || now,\n    station: station.ident,\n    country: station.country_code,\n    flight: flight.flight_iata || flight.flight_icao || flight.flight,\n    airframe_icao: airframe.icao,\n    tail: airframe.tail || event.tail,\n    military: airframe.military,\n    source: event.source,\n    source_type: event.source_type,\n    frequency: event.frequency,\n    label: event.label,\n    mode: event.mode,\n    text: event.text,\n    raw: event\n};\n\nlet recent = flow.get(\"airframes_recent\") || [];\nrecent.unshift(normalized);\nrecent = recent.slice(0, 500);\nflow.set(\"airframes_recent\", recent);\n\nconst debugMsg = { payload: normalized };\nconst fileMsg = { payload: JSON.stringify(normalized) };\nconst responseMsg = {\n    req: msg.req,\n    res: msg.res,\n    statusCode: 200,\n    headers: { \"content-type\": \"application/json\" },\n    payload: { ok: true, id: normalized.id, received_at: normalized.received_at }\n};\n\nreturn [debugMsg, fileMsg, responseMsg];",
